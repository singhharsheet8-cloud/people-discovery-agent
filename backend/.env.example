# ============================================================
# People Discovery Agent — Environment Configuration
# ============================================================

# ---- LLM Provider Keys (set at least one) ----

# Option A: OpenAI (default — uses gpt-5-mini for planning)
OPENAI_API_KEY=sk-...

# Option B: Anthropic (used for synthesis when model starts with "claude")
ANTHROPIC_API_KEY=sk-ant-...

# Option C: Groq — ultra-fast inference, great free tier
#   Models: llama-3.3-70b-versatile, qwen-qwq-32b, mixtral-8x7b-32768
GROQ_API_KEY=gsk_...

# Option D: Together AI — widest open-source model selection
#   Models: deepseek-ai/DeepSeek-V3, meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_API_KEY=...

# ---- Model Configuration ----

# Planning model (tool calling, runs 3-5x per query — keep cheap)
# Default: gpt-5-mini ($0.25/$2.00 per 1M tokens)
# Groq:    llama-3.3-70b-versatile (free tier!) or qwen-qwq-32b
# Together: deepseek-ai/DeepSeek-V3 ($0.14/$0.28 per 1M)
PLANNING_MODEL=gpt-5-mini

# Base URL override for open-source providers (leave blank for OpenAI)
# Groq:      https://api.groq.com/openai/v1
# Together:  https://api.together.xyz/v1
PLANNING_BASE_URL=

# Synthesis model (profile generation, runs once — use best quality)
# Default: claude-sonnet-4-5-20241022 ($3/$15)
# Budget:  gpt-5-mini or deepseek-ai/DeepSeek-V3
SYNTHESIS_MODEL=claude-sonnet-4-5-20241022

# ---- Search APIs ----
TAVILY_API_KEY=tvly-...

# Optional: YouTube Data API (falls back to Tavily YouTube search if not set)
YOUTUBE_API_KEY=

# Optional: GitHub Personal Access Token (raises rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# ---- Infrastructure ----

# Database (SQLite default, PostgreSQL for production)
# PostgreSQL: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./discovery.db

# Cache TTL in seconds (default 1 hour)
CACHE_TTL_SECONDS=3600

# ---- App ----
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
