# ============================================================
# People Discovery Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# Only OPENAI_API_KEY and TAVILY_API_KEY are required.
# Everything else has sensible defaults.
# ============================================================

# ---- Required API Keys ----

# OpenAI — used for both planning (gpt-4.1-mini) and synthesis (gpt-5-mini)
OPENAI_API_KEY=sk-...

# Tavily — web search API (get free key at https://tavily.com)
TAVILY_API_KEY=tvly-...

# ---- Optional API Keys ----

# GitHub Personal Access Token — raises API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# YouTube Data API v3 — dedicated video search (falls back to Tavily if unset)
YOUTUBE_API_KEY=

# Anthropic — only needed if you set SYNTHESIS_MODEL to a Claude model
ANTHROPIC_API_KEY=

# ---- Model Configuration ----

# Planning model — runs 3-5x per query for planning and analysis
# Default: gpt-4.1-mini (fast JSON output, ~$0.40/$1.60 per 1M tokens)
# Alternatives: llama-3.3-70b-versatile (Groq), deepseek-ai/DeepSeek-V3 (Together)
PLANNING_MODEL=gpt-4.1-mini

# Synthesis model — runs once per query for final profile generation
# Default: gpt-5-mini (reasoning model for rich, detailed profiles)
# Alternatives: gpt-4.1-mini (cheaper), claude-sonnet-4-5-20241022 (Anthropic)
SYNTHESIS_MODEL=gpt-5-mini

# Base URL override — set this ONLY if using Groq or Together AI for planning
# Groq:     https://api.groq.com/openai/v1
# Together: https://api.together.xyz/v1
# Leave blank to use OpenAI (default)
PLANNING_BASE_URL=

# Groq API key — only needed if PLANNING_BASE_URL points to Groq
GROQ_API_KEY=

# Together AI key — only needed if PLANNING_BASE_URL points to Together
TOGETHER_API_KEY=

# ---- Infrastructure ----

# Database — SQLite for local dev, PostgreSQL for production
# PostgreSQL example: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/discovery.db

# Search result cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# ---- App Settings ----

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
