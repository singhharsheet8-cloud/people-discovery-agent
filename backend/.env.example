# ──────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# ──────────────────────────────────────────────
# Deep Search Sources (optional but recommended)
# ──────────────────────────────────────────────
APIFY_API_KEY=apify_api_...
FIRECRAWL_API_KEY=fc-...
SERPAPI_API_KEY=...
SOCIAVAULT_API_KEY=...
GITHUB_TOKEN=ghp_...           # Optional — higher rate limits
YOUTUBE_API_KEY=...            # Optional — improves YouTube search

# ──────────────────────────────────────────────
# Synthesis LLM (choose one or leave blank to use GPT-4.1 Mini)
# ──────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# Alternative planning LLM providers (OpenAI-compatible)
# ──────────────────────────────────────────────
GROQ_API_KEY=gsk_...           # Optional — ultra-fast inference
TOGETHER_API_KEY=...           # Optional — open-source models
PLANNING_BASE_URL=             # Set to Groq/Together base URL when using them

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./discovery.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/discovery
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_RECYCLE=1800

# ──────────────────────────────────────────────
# LLM Model Selection
# ──────────────────────────────────────────────
PLANNING_MODEL=gpt-4.1-mini
SYNTHESIS_MODEL=deepseek-chat  # or: claude-3-5-sonnet-20241022, gpt-4.1-mini

# ──────────────────────────────────────────────
# Discovery Guardrails
# ──────────────────────────────────────────────
MAX_CONCURRENT_JOBS=5
MAX_DAILY_DISCOVERIES=100

# ──────────────────────────────────────────────
# Admin Credentials
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@discovery.local
ADMIN_PASSWORD=changeme123

# ──────────────────────────────────────────────
# JWT (set for persistent sessions across restarts)
# ──────────────────────────────────────────────
JWT_SECRET_KEY=your-secure-random-secret-here

# ──────────────────────────────────────────────
# Frontend CORS
# ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
CORS_ALLOW_REGEX=https://your-app.*\.vercel\.app

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=
ENVIRONMENT=development

# ──────────────────────────────────────────────
# Redis (optional — for distributed rate limiting)
# ──────────────────────────────────────────────
REDIS_URL=
