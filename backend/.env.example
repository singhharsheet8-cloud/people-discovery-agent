# Required API Keys
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Deep Search Sources (optional but recommended)
APIFY_API_KEY=apify_api_...
FIRECRAWL_API_KEY=fc-...
SERPAPI_API_KEY=...
SOCIAVAULT_API_KEY=...
