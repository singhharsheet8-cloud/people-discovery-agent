# Required API Keys
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Deep Search Sources (optional but recommended)
APIFY_API_KEY=apify_api_...
FIRECRAWL_API_KEY=fc-...
SERPAPI_API_KEY=...
SOCIAVAULT_API_KEY=...
DEEPSEEK_API_KEY=sk-...

# GitHub (optional, higher rate limits with token)
GITHUB_TOKEN=ghp_...

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/discovery
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_RECYCLE=1800

# Discovery Guardrails
MAX_CONCURRENT_JOBS=5
MAX_DAILY_DISCOVERIES=100

# Admin Credentials
ADMIN_EMAIL=admin@discovery.local
ADMIN_PASSWORD=changeme123

# JWT Secret (auto-generated if not set, but set for persistent sessions)
JWT_SECRET_KEY=your-secure-random-secret-here

# LLM Configuration
PLANNING_MODEL=gpt-4.1-mini
SYNTHESIS_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Frontend
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Logging
LOG_LEVEL=INFO
